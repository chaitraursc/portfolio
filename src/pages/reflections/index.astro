---
import BaseLayout from "../../layouts/BaseLayout.astro";

const modules = import.meta.glob("../../content/reflections/*.md", { eager: true });

const posts = Object.entries(modules).map(([path, mod]: [string, any]) => ({
  slug: path.split("/").pop()?.replace(".md", ""),
  frontmatter: mod.frontmatter,
}));

const sorted = posts.sort(
  (a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
);
---

<BaseLayout title="Reflections" description="Writing by Chaitra.">
  <section class="max-w-2xl">
    <h1 class="text-4xl font-serif text-[#2C1A0E] mb-4">Reflections</h1>
    <p class="text-[#8B7355] mb-12 font-light">Thoughts on building, leading, and learning.</p>

    {sorted.length === 0 && (
      <p class="text-[#8B7355] font-light">Nothing here yet — check back soon.</p>
    )}

    <div class="space-y-10">
      {sorted.map(({ slug, frontmatter }) => {
        const formattedDate = new Date(frontmatter.date).toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        return (
          <a href={`/reflections/${slug}`} class="group block border-b border-[#D4A574]/30 pb-8">
            <p class="text-xs tracking-widest uppercase text-[#8B7355] mb-2">{formattedDate}</p>
            <h2 class="text-xl font-serif text-[#2C1A0E] group-hover:text-[#A0522D] transition-colors">
              {frontmatter.title}
            </h2>
            {frontmatter.description && (
              <p class="mt-2 text-[#8B7355] font-light text-sm leading-relaxed">
                {frontmatter.description}
              </p>
            )}
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
