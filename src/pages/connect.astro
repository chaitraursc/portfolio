---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Connect" description="Get in touch with Chaitra.">
  <section class="max-w-2xl">
    <h1 class="text-4xl font-serif text-[#2C1A0E] mb-4">Connect</h1>
    <p class="text-[#8B7355] mb-12 font-light leading-relaxed">
      Whether it's a project idea, a question, or just a hello — I'm happy to hear from you.
    </p>

    <div class="space-y-6 mb-16">
      <a href="mailto:chaitraursc@outlook.com"
        class="flex items-center gap-4 group">
        <span class="text-xs tracking-widest uppercase text-[#A0522D] w-20">Email</span>
        <span class="text-[#2C1A0E] group-hover:text-[#A0522D] transition-colors border-b border-[#D4A574]/40 pb-0.5">
          chaitraursc@outlook.com
        </span>
      </a>
      <a href="https://github.com/chaitraursc" target="_blank" rel="noopener noreferrer"
        class="flex items-center gap-4 group">
        <span class="text-xs tracking-widest uppercase text-[#A0522D] w-20">GitHub</span>
        <span class="text-[#2C1A0E] group-hover:text-[#A0522D] transition-colors border-b border-[#D4A574]/40 pb-0.5">
          chaitraursc
        </span>
      </a>
      <a href="https://www.linkedin.com/in/chaitra-urs-94227577/" target="_blank" rel="noopener noreferrer"
        class="flex items-center gap-4 group">
        <span class="text-xs tracking-widest uppercase text-[#A0522D] w-20">LinkedIn</span>
        <span class="text-[#2C1A0E] group-hover:text-[#A0522D] transition-colors border-b border-[#D4A574]/40 pb-0.5">
          Chaitra Urs
        </span>
      </a>
    </div>
  </section>
</BaseLayout>
