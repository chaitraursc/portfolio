---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Bio" description="About Chaitra — developer and project manager.">
  <section class="max-w-2xl">
    <h1 class="text-4xl font-serif text-[#2C1A0E] mb-10">Bio</h1>

    <div class="space-y-6 text-[#2C1A0E] leading-relaxed text-lg font-light">
      <p>
        I'm Chaitra — a developer and project manager who sits comfortably at the intersection of building and leading.
      </p>
      <p>
        Over the years I've worked across roles: writing code, shipping features, coordinating teams, and managing the moving parts that make projects actually land. I care about clarity — in systems, in communication, and in design.
      </p>
      <p>
        When I'm not working, I'm thinking about how things are made and why some of them last.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-10">
      <div>
        <h2 class="text-xs tracking-widest uppercase text-[#A0522D] mb-4">Development</h2>
        <ul class="space-y-2 text-[#8B7355] text-sm">
          <li>Python</li>
          <li>JavaScript / TypeScript</li>
          <li>Web & API development</li>
          <li>AI / automation tools</li>
        </ul>
      </div>
      <div>
        <h2 class="text-xs tracking-widest uppercase text-[#A0522D] mb-4">Management</h2>
        <ul class="space-y-2 text-[#8B7355] text-sm">
          <li>Project planning & delivery</li>
          <li>Cross-functional coordination</li>
          <li>Stakeholder communication</li>
          <li>Process improvement</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
